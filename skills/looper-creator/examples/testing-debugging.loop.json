{
  "agents": [
    {
      "context_scope": "shared",
      "id": "orchestrator",
      "may_modify": [
        "PROGRESS.md",
        "state.json",
        "tasks.json"
      ],
      "model_class": "strong_reasoning",
      "responsibilities": [
        "maintain plan",
        "dispatch tasks",
        "decide exits"
      ],
      "role": "orchestrator"
    },
    {
      "context_scope": "task_private",
      "id": "worker",
      "may_modify": [
        "source files",
        "tests"
      ],
      "model_class": "fast_worker",
      "responsibilities": [
        "execute one atomic task"
      ],
      "role": "worker"
    },
    {
      "context_scope": "review_private",
      "id": "reviewer",
      "may_modify": [
        "review report"
      ],
      "model_class": "strong_reasoning",
      "responsibilities": [
        "review task output against acceptance criteria"
      ],
      "role": "reviewer"
    }
  ],
  "atomic_tasks": [
    {
      "acceptance_criteria": [
        "unit-tests verifier exits 0",
        "reviewer accepts diff"
      ],
      "assigned_agent": "worker",
      "dependencies": [],
      "estimated_token_budget": 20000,
      "goal": "Create or run the failing reproduction, fix the root cause, and verify the regression check.",
      "id": "testing-debugging-task-1",
      "input_refs": [
        "requirements.md",
        "src/"
      ],
      "max_attempts": 3,
      "output_artifacts": [
        "source diff",
        "test diff"
      ],
      "tools": [
        "shell",
        "apply_patch"
      ],
      "verification_refs": [
        "unit-tests"
      ]
    }
  ],
  "clarification_policy": {
    "ambiguity_triggers": [
      "acceptance criteria missing",
      "target environment unclear",
      "permission boundary unclear"
    ],
    "assumption_policy": {
      "allowed": "Only low-risk implementation details may be assumed.",
      "record_path": "PROGRESS.md"
    },
    "block_if": [
      "security impact unclear",
      "production data impact unclear"
    ],
    "default_action": "ask_user",
    "secondary_user_query": {
      "max_questions": 3,
      "prompt": "Which target feature, acceptance criteria, and verification command should this loop use?",
      "required_when": [
        "acceptance criteria missing",
        "verification command missing"
      ]
    }
  },
  "collaboration_policy": {
    "handoff_contract": {
      "required_fields": [
        "task_id",
        "context_pack",
        "expected_output",
        "verification_refs"
      ],
      "return_fields": [
        "status",
        "artifacts",
        "evidence",
        "open_questions"
      ]
    },
    "patterns": [
      "orchestrator_workers",
      "evaluator_optimizer"
    ],
    "subagent_activation": {
      "allowed_when": [
        "tasks are independent",
        "context would exceed single-agent budget",
        "independent review is required"
      ],
      "disallowed_when": [
        "shared mutable file would be edited by multiple workers"
      ],
      "token_budget_policy": "subagents must return distilled summaries under 2000 tokens"
    }
  },
  "context_policy": {
    "compaction": {
      "summary_contract": "preserve decisions, open tasks, verification evidence, and risks",
      "trigger_ratio": 0.8
    },
    "durable_memory": {
      "journal_path": "journal.jsonl",
      "progress_path": "PROGRESS.md",
      "state_path": "state.json"
    },
    "excluded_context": [
      "secrets",
      "raw tokens",
      "unrelated logs"
    ],
    "max_context_tokens": 60000,
    "required_context_pack": [
      "loop.json",
      "state.json",
      "PROGRESS.md"
    ],
    "retrieval_strategy": "just_in_time",
    "tool_output_trimming": "include only commands, exit codes, failing assertions, and changed paths"
  },
  "cost_policy": {
    "optimization_goal": "minimize repeated context loading while preserving verification evidence",
    "stop_when_marginal_value_low": true,
    "token_budget_by_agent": {
      "orchestrator": 80000,
      "reviewer": 30000,
      "worker": 40000
    }
  },
  "decomposition_policy": {
    "dependency_policy": "parents cannot complete until all children and verification refs pass",
    "max_depth": 4,
    "minimum_task_granularity": "one independently verifiable code, test, docs, or review change",
    "split_until": [
      "each task has one owner agent",
      "each task has machine-checkable acceptance criteria",
      "each task can fit inside its context token budget"
    ],
    "strategy": "recursive_task_graph"
  },
  "escalation": {
    "channel": "Codex thread",
    "condition": "budget, no-progress, ambiguity, or human-gate exit is reached",
    "message_template": "Loop Testing Debugging Loop stopped: {reason}. Evidence: {evidence_ref}.",
    "owner": "human maintainer"
  },
  "execution_adapters": [
    {
      "approval_model": "sandbox_and_policy",
      "context_reload_model": "session_instruction_discovery",
      "deterministic_hooks": "not_assumed",
      "generated_files": [
        "AGENTS.md"
      ],
      "instruction_files": [
        "AGENTS.md"
      ],
      "subagent_activation": "explicit_request",
      "supports_subagents": true,
      "target": "codex",
      "unsupported_capability_behavior": "block_and_report"
    },
    {
      "approval_model": "permissions_and_hooks",
      "context_reload_model": "CLAUDE.md_and_memory",
      "deterministic_hooks": "supported",
      "generated_files": [
        "CLAUDE.md",
        ".claude/settings.json"
      ],
      "instruction_files": [
        "CLAUDE.md"
      ],
      "subagent_activation": "description_or_explicit_agent",
      "supports_subagents": true,
      "target": "claude_code",
      "unsupported_capability_behavior": "block_and_report"
    },
    {
      "approval_model": "cursor_agent_security",
      "context_reload_model": "rules_skills_mentions",
      "deterministic_hooks": "supported_when_configured",
      "generated_files": [
        ".cursor/rules/looper-creator.mdc"
      ],
      "instruction_files": [
        "AGENTS.md",
        ".cursor/rules/looper-creator.mdc"
      ],
      "subagent_activation": "cursor_subagents_or_cloud_agents",
      "supports_subagents": true,
      "target": "cursor",
      "unsupported_capability_behavior": "block_and_report"
    }
  ],
  "failure_modes": [
    {
      "id": "vague-objective",
      "mitigation": "trigger clarification_policy.secondary_user_query"
    },
    {
      "id": "context-bloat",
      "mitigation": "trim tool outputs and compact at threshold"
    },
    {
      "id": "no-progress",
      "mitigation": "compare fingerprints and stop at threshold"
    }
  ],
  "human_gates": {
    "approval_record_path": "PROGRESS.md",
    "irreversible_actions": [
      "git push",
      "merge pull request",
      "deploy to production"
    ]
  },
  "kind": "RecursiveLoopOrchestration",
  "loop_nodes": [
    {
      "agent_assignments": [
        "orchestrator"
      ],
      "children": [
        {
          "agent_assignments": [
            "worker",
            "reviewer"
          ],
          "context_pack": [
            "task card",
            "relevant source files",
            "verifier output"
          ],
          "entry_conditions": [
            "atomic_tasks ready"
          ],
          "exit_conditions": [
            "all child tasks accepted",
            "no_progress_exit"
          ],
          "id": "implementation-cycle",
          "purpose": "Iterate implementation tasks until per-task verification passes.",
          "steps": [
            "assign_task",
            "implement",
            "self_check",
            "deterministic_check",
            "review"
          ],
          "type": "evaluator_optimizer_loop",
          "verification_refs": [
            "unit-tests"
          ]
        }
      ],
      "context_pack": [
        "loop.json",
        "PROGRESS.md",
        "state.json"
      ],
      "entry_conditions": [
        "clarification_policy satisfied",
        "state.status is planned or running"
      ],
      "exit_conditions": [
        "terminal_verification_passed",
        "budget_exit_reached",
        "human_gate_required"
      ],
      "id": "root",
      "purpose": "Coordinate recursive decomposition and terminal verification.",
      "steps": [
        "load_context",
        "decompose",
        "dispatch_children",
        "verify",
        "record"
      ],
      "type": "agent_loop",
      "verification_refs": [
        "terminal"
      ]
    }
  ],
  "metadata": {
    "description": "Reproduce, isolate, fix, and verify one failing behavior without masking the root cause.",
    "id": "testing-debugging",
    "locale": "en",
    "name": "Testing Debugging Loop"
  },
  "objective": {
    "business_value": "Reduce repeated agent context loading while preserving deterministic completion evidence.",
    "done_definition": "The original failure reproduces before the fix and passes after the fix, with regression evidence recorded.",
    "non_goals": [
      "Do not deploy automatically",
      "Do not rewrite unrelated modules"
    ],
    "user_goal": "Turn a confirmed failing test or runtime symptom into a verified fix."
  },
  "observability": {
    "evidence_dir": "evidence",
    "trace_fields": [
      "loop_node_id",
      "task_id",
      "agent_id",
      "verifier_id",
      "token_estimate"
    ]
  },
  "portability_policy": {
    "adapter_outputs_are_generated": true,
    "canonical_manifest": "loop.json",
    "do_not_weaken_verification_for_platform_limits": true,
    "platform_selection_query": "Which agent runtime should this loop target: codex, claude_code, cursor, or portable?",
    "unsupported_capability_behavior": "block_and_report"
  },
  "risk_policy": {
    "forbidden_behaviors": [
      "silent fallback",
      "weakening validation",
      "storing plaintext secrets"
    ],
    "high_risk_requires_human": [
      "security",
      "production data",
      "billing",
      "deployment"
    ],
    "risk_levels": [
      "low",
      "medium",
      "high",
      "critical"
    ]
  },
  "schema_version": "2.0",
  "state": {
    "journal_path": "journal.jsonl",
    "path": "state.json",
    "progress_path": "PROGRESS.md"
  },
  "templates": [
    "testing-debugging"
  ],
  "termination_policy": {
    "budget_exits": {
      "max_iterations": 8,
      "max_tokens": 180000,
      "wall_clock_minutes": 90
    },
    "failure": [
      "required dependency unavailable",
      "protected verifier must change"
    ],
    "human_gate": [
      "before git push",
      "before production deploy"
    ],
    "no_progress": {
      "fingerprint_fields": [
        "git_head",
        "open_task_ids",
        "verifier_failures"
      ],
      "max_stale_iterations": 2
    },
    "success": [
      "terminal verification commands exit 0",
      "all atomic tasks accepted"
    ]
  },
  "verification_policy": {
    "anti_gaming_rules": [
      "do not delete tests",
      "do not weaken verifier commands",
      "do not add continue-on-error"
    ],
    "protected_paths": [
      "scripts/verify.sh",
      ".github/workflows",
      "tests"
    ],
    "verifiers": [
      {
        "command": "python3 -m unittest discover -s tests",
        "expected_result": "exit code 0",
        "id": "unit-tests",
        "scope": "per_task"
      },
      {
        "command": "bash scripts/verify.sh",
        "expected_result": "exit code 0",
        "id": "terminal",
        "scope": "terminal"
      }
    ]
  },
  "acceptance_checklist": {
    "path": "ACCEPTANCE.md",
    "update_policy": "Only mark a checklist item complete after all acceptance criteria pass and verification refs have durable evidence artifacts.",
    "items": [
      {
        "id": "accept-testing-debugging-task-1",
        "task_id": "testing-debugging-task-1",
        "description": "Create or run the failing reproduction, fix the root cause, and verify the regression check.",
        "owner_agent": "worker",
        "acceptance_criteria": [
          "unit-tests verifier exits 0",
          "reviewer accepts diff"
        ],
        "verification_refs": [
          "unit-tests"
        ],
        "evidence_refs": [
          "source diff",
          "test diff"
        ]
      }
    ]
  }
}
