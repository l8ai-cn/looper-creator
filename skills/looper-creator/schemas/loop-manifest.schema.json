{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/looper-creator/loop-manifest.schema.json",
  "title": "Looper Creator Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "name",
    "purpose",
    "trigger",
    "observation",
    "action",
    "success_condition",
    "failure_condition",
    "verifier",
    "budgets",
    "no_progress",
    "state",
    "escalation",
    "human_gates"
  ],
  "properties": {
    "schema_version": { "const": "1.0" },
    "name": { "type": "string", "minLength": 1 },
    "purpose": { "type": "string", "minLength": 1 },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "description"],
      "properties": {
        "type": { "enum": ["heartbeat", "cron", "hook", "goal"] },
        "description": { "type": "string", "minLength": 1 },
        "schedule": { "type": "string", "minLength": 1 },
        "event_source": { "type": "string", "minLength": 1 },
        "backpressure": { "type": "string", "minLength": 1 }
      }
    },
    "observation": { "$ref": "#/$defs/described" },
    "action": { "$ref": "#/$defs/described" },
    "success_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "check_command": { "type": "string", "minLength": 1 },
        "evidence": { "type": "string", "minLength": 1 }
      },
      "anyOf": [
        { "required": ["check_command"] },
        { "required": ["evidence"] }
      ]
    },
    "failure_condition": { "$ref": "#/$defs/described" },
    "verifier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["command", "expected_result", "protected_paths"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "expected_result": { "type": "string", "minLength": 1 },
        "protected_paths": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "budgets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_iterations", "wall_clock_minutes"],
      "properties": {
        "max_iterations": { "type": "integer", "minimum": 1 },
        "wall_clock_minutes": { "type": "integer", "minimum": 1 },
        "max_tokens": { "type": "integer", "minimum": 1 },
        "max_cost_usd": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "no_progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fingerprint_fields", "max_stale_iterations"],
      "properties": {
        "fingerprint_fields": {
          "type": "array",
          "minItems": 2,
          "items": { "type": "string", "minLength": 1 }
        },
        "max_stale_iterations": { "type": "integer", "minimum": 1 }
      }
    },
    "state": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "journal_path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "journal_path": { "type": "string", "minLength": 1 }
      }
    },
    "escalation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["condition", "owner", "channel", "message_template"],
      "properties": {
        "condition": { "type": "string", "minLength": 1 },
        "owner": { "type": "string", "minLength": 1 },
        "channel": { "type": "string", "minLength": 1 },
        "message_template": { "type": "string", "minLength": 1 }
      }
    },
    "human_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["irreversible_actions"],
      "properties": {
        "irreversible_actions": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  },
  "$defs": {
    "described": {
      "type": "object",
      "additionalProperties": false,
      "required": ["description"],
      "properties": {
        "description": { "type": "string", "minLength": 1 }
      }
    }
  }
}
